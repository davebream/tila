{
  "name": "tila-sdk",
  "version": "0.1.2",
  "license": "MIT",
  "description": "TypeScript SDK for tila \u2014 durable state & coordination for multi-machine agentic work",
  "keywords": [
    "tila",
    "sdk",
    "agentic",
    "ai-agents",
    "agent-coordination",
    "state-management",
    "typescript"
  ],
  "author": "Dawid Leszczy\u0144ski (https://github.com/davebream)",
  "homepage": "https://github.com/davebream/tila#readme",
  "bugs": "https://github.com/davebream/tila/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davebream/tila.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./local": {
      "import": {
        "types": "./dist/local.d.ts",
        "default": "./dist/local.js"
      },
      "require": {
        "types": "./dist/local.d.cts",
        "default": "./dist/local.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/gen-version.mjs && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:version": "node scripts/gen-version.mjs"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11 <13"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tila/backend-embedded": "workspace:*",
    "@tila/core": "workspace:*",
    "@tila/ops-sqlite": "workspace:*",
    "@tila/schemas": "workspace:*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
