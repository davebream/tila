{
  "name": "tila-sdk",
  "version": "0.1.0",
  "license": "MIT",
  "description": "TypeScript SDK for tila — durable state & coordination for multi-machine agentic work",
  "keywords": [
    "tila",
    "sdk",
    "agentic",
    "ai-agents",
    "agent-coordination",
    "state-management",
    "typescript"
  ],
  "author": "Dawid Leszczyński (https://github.com/davebream)",
  "homepage": "https://github.com/davebream/tila#readme",
  "bugs": "https://github.com/davebream/tila/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davebream/tila.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tila/schemas": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
