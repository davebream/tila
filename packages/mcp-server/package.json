{
  "name": "tila-mcp-server",
  "version": "0.1.0",
  "license": "MIT",
  "description": "MCP server for tila — enables Claude Code, Cursor, and VS Code Copilot integration",
  "keywords": [
    "tila",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agents",
    "claude",
    "cursor",
    "agentic"
  ],
  "author": "Dawid Leszczyński (https://github.com/davebream)",
  "homepage": "https://github.com/davebream/tila#readme",
  "bugs": "https://github.com/davebream/tila/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davebream/tila.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.davebream/tila",
  "type": "module",
