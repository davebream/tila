  },
  "devDependencies": {
    "@tila/schemas": "workspace:*",
    "tila-sdk": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
